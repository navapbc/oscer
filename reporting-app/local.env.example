############################
# Rails
############################

RAILS_ENV=development

# Time Zone listings/mappings can be found at https://api.rubyonrails.org/classes/ActiveSupport/TimeZone.html
# TIME_ZONE="Eastern Time (US & Canada)"

############################
# Rails: Urls
############################

APP_HOST=localhost
APP_PORT=3000

# Skip PublicRequestHost middleware (truthy: 1, true, yes, on). Set on the Rails process when
# running Playwright E2E against localhost while APP_HOST is set for OIDC callback URLs.
# SKIP_PUBLIC_REQUEST_HOST=true

############################
# AWS services
############################

AWS_ACCESS_KEY_ID=<FILL ME IN>
AWS_SECRET_ACCESS_KEY=<FILL ME IN>
AWS_DEFAULT_REGION=<FILL ME IN>

############################
# File storage
############################

# Uncomment and fill in an AWS S3 bucket name to use S3 for file storage
# BUCKET_NAME=<FILL ME IN>

############################
# Auth
############################

COGNITO_USER_POOL_ID=<FILL ME IN>
COGNITO_CLIENT_ID=<FILL ME IN>
COGNITO_CLIENT_SECRET=<FILL ME IN>

# "mock" to enable local login with any email/password combo; "cognito" to use the proper authentication flow
AUTH_ADAPTER="mock"

############################
# Database
############################

DB_HOST=127.0.0.1
DB_NAME=app
DB_USER=app
DB_PASSWORD=secret123
DB_PORT=5432

############################
# Staff SSO (Single Sign-On)
############################

# Enable/disable SSO login option on sign-in page
SSO_ENABLED=false

# Identity Provider (IdP) configuration (required when SSO_ENABLED=true)
# Uses omniauth-openid-connect gem with automatic OIDC Discovery
# SSO_ISSUER_URL=https://login.microsoftonline.com/{tenant-id}/v2.0
# SSO_CLIENT_ID=<FILL ME IN>
# SSO_CLIENT_SECRET=<FILL ME IN>

# For local development with Keycloak (included in docker-compose.yml):
# - If running Rails on host machine: SSO_ISSUER_URL=http://localhost:8080/realms/oscer
# - If running Rails in Docker:       SSO_ISSUER_URL=http://keycloak:8080/realms/oscer
# SSO_ISSUER_URL=http://localhost:8080/realms/oscer
# SSO_CLIENT_ID=oscer-staff
# SSO_CLIENT_SECRET=<from Keycloak admin>

# Optional: Custom scopes (default: openid profile email)
# SSO_SCOPES=openid profile email groups

# Optional: Custom claim names (defaults shown)
# SSO_CLAIM_EMAIL=email
# SSO_CLAIM_NAME=name
# SSO_CLAIM_GROUPS=groups
# SSO_CLAIM_UID=sub

############################
# DocAI
############################

# Enable document staging and activity pre-fill from DocAI extraction.
# See docs/how-to-guides/configuring-doc-ai.md for full configuration details.
FEATURE_DOC_AI=false

# Required when FEATURE_DOC_AI=true. Base URL of the strata-service-document-ai instance.
# When running the doc-ai service locally via its own compose stack, use the service
# container name instead of localhost. Start the app with the override file:
#   docker compose -f docker-compose.yml -f docker-compose.doc-ai.yml up
# then set:
# DOC_AI_API_HOST=http://strata-service-document-ai-service:8080
#
# Without the override (e.g. running the doc-ai service outside Docker):
# DOC_AI_API_HOST=http://localhost:8080

# Optional: API request timeout in seconds (default: 60).
# DOC_AI_TIMEOUT_SECONDS=60

# Optional: confidence threshold for task queue prioritization (range 0.0-1.0, default: 0.7).
# Activities with average confidence below this are flagged for higher caseworker priority.
# DOC_AI_LOW_CONFIDENCE_THRESHOLD=0.7

# API key — must match API_AUTH_INSECURE_SHARED_KEY (or API_AUTH_KEYS) set on the service.
# In strata-service-document-ai, set API_AUTH_INSECURE_SHARED_KEY=test in your .env file
# (or add "test" to API_AUTH_KEYS) so the two values agree.
# DOC_AI_API_KEY=test

############################
# Demo certifications
############################

# Enable the demo certification seeding UI (GET /demo, GET/POST
# /demo/certifications). This tooling creates real Certification records with no
# authentication, so it is disabled by default and must never be enabled in
# production. In development and test it is always available regardless of this
# flag; set it to true only to exercise the flag-gated path locally under
# RAILS_ENV=development.
FEATURE_DEMO_CERTIFICATIONS=false

############################
# Lookbook
############################

ENABLE_LOOKBOOK=true
