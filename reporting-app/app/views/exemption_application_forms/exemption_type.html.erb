<% content_for :title, t(".title") %>

<%= render "exemption_step_indicator", current_step: :exemption_type %>

<h1><%= t(".heading") %></h1>

<%= strata_form_with(model: @exemption_application_form, data: { turbo: false }) do |f| %>
  <%= f.hidden_field :certification_case_id %>

  <%= f.radio_button :exemption_type, "short_term_hardship", { label: t(".short_term_hardship_label"), hint: t(".short_term_hardship_hint") } %>
  <%= f.radio_button :exemption_type, "incarceration", { label: t(".incarceration_label"), hint: t(".incarceration_hint") } %>

  <%= f.submit t(".continue_button") %>
<% end %>

