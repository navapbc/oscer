<%= content_for :title, t(".title") %>

<%= render "strata/shared/step_indicator", steps: %i[start select_periods add_activities review], current_step: :start, translation_scope: "activity_report_application_forms.steps" %>

<h1><%= t(".title") %></h1>
<dl class="grid-row margin-bottom-0">
  <dt class="grid-col flex-auto"><strong><%= t(".time_to_complete_description") %></strong></dt>
  <dd class="grid-col flex-auto margin-left-1"><%= t(".time_to_complete") %></dd>
</dl>
<p class="margin-top-0"><%= t(".instructions") %></p>
<ul>
  <li><%= t(".what_you_need.item_1") %></li>
  <li><%= t(".what_you_need.item_2") %></li>
</ul>
<p><%= t(".save_info") %></p>
<%= link_to t(".start_button"),
  edit_activity_report_application_form_path(@activity_report_application_form),
  class: "usa-button"
%>
