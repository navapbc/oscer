<%= content_for :title, t(".title") %>

<%= render "strata/shared/step_indicator", steps: %i[start select_periods add_activities review submitted], current_step: :start, translation_scope: "activity_report_application_forms.steps" %>

<h1><%= t(".title") %></h1>
<dl class="grid-row margin-bottom-0">
  <dt class="grid-col flex-auto"><strong><%= t(".time_to_complete_description") %></strong></dt>
  <dd class="grid-col flex-auto margin-left-1"><%= t(".time_to_complete") %></dd>
</dl>
<p class="margin-top-0"><%= t(".instructions") %></p>
<ul>
  <li><%= t(".what_you_need.item_1") %></li>
  <li><%= t(".what_you_need.item_2") %></li>
</ul>
<p><%= t(".save_info") %></p>
<% if feature_enabled?(:doc_ai) %>
  <div class="usa-summary-box margin-bottom-3" role="region" aria-labelledby="doc-ai-callout">
    <div class="usa-summary-box__body">
      <h3 class="usa-summary-box__heading display-flex flex-align-center" id="doc-ai-callout">
        <%= t(".doc_ai.callout_heading") %>
      </h3>
      <div class="usa-summary-box__text">
        <p><%= t(".doc_ai.callout_body") %></p>
      </div>
    </div>
  </div>
<% end %>
<%= strata_form_with(model: ActivityReportApplicationForm.new) do |f| %>
  <%= f.hidden_field :certification_case_id, value: @certification_case.id %>
  <% if feature_enabled?(:doc_ai) %>
    <div class="doc-ai-skip-checkbox">
      <%= f.check_box :skip_ai, { label: t(".doc_ai.skip_ai_label") } %>
    </div>
  <% end %>
  <%= f.submit t(".start_button") %>
<% end %>
