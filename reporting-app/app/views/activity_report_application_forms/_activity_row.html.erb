<div id="<%= dom_id activity %>" class="grid-row">
  <div class="grid-col-7 grid-offset-1">
    <%= link_to "Work for #{activity.name}", [activity_report_application_form, activity.becomes(Activity)] %>
  </div>
  <div class="grid-col-2 text-right">
    <%= activity.try(:hours) %>
  </div>
  <div class="grid-col-2 text-right">
    <%= number_to_currency(activity.try(:earned_income)&.cents_amount) %>
  </div>
</div>
