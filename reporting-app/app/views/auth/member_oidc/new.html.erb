<% content_for(:title) { t("auth.member_oidc.redirecting_title") } %>

<div class="sso-redirect-container">
  <div class="sso-redirect-spinner"></div>
  <p><%= t("auth.member_oidc.redirecting_message") %></p>

  <%# Auto-submit form to OmniAuth via POST (more secure than GET redirect) %>
  <%= form_with url: "/auth/member_oidc",
                method: :post,
                local: true,
                authenticity_token: true,
                data: { turbo: false, controller: "sso-redirect" } do %>
    <% if @origin.present? %>
      <%= hidden_field_tag :origin, @origin %>
    <% end %>
    <noscript>
      <p><%= t("auth.member_oidc.javascript_required") %></p>
      <%= submit_tag t("auth.member_oidc.continue_button"), class: "usa-button" %>
    </noscript>
  <% end %>
</div>
