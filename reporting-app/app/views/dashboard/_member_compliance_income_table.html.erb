<%# Data-driven income table for the member dashboard (OSCER-642).
    Mirrors the staff certification_cases/_income_reported_table columns and footer. %>
<% compliance = local_assigns.fetch(:compliance) %>
<% i18n = "dashboard.member_compliance.income_table" %>

<h3 class="font-heading-md margin-bottom-2"><%= t("#{i18n}.title") %></h3>
<table class="usa-table width-full member-dashboard-compliance__table">
  <thead>
    <tr>
      <th scope="col"><%= t("#{i18n}.organization_name") %></th>
      <th scope="col"><%= t("#{i18n}.source") %></th>
      <th scope="col"><%= t("#{i18n}.activity_type") %></th>
      <th scope="col"><%= t("#{i18n}.income_reported") %></th>
    </tr>
  </thead>
  <tbody>
    <% compliance.income_table_rows.each do |row| %>
      <tr>
        <td><%= row.organization_name %></td>
        <td><%= member_compliance_source_label(row.source_token) %></td>
        <td><%= row.activity_type_label %></td>
        <td>
          <% if row.amount.nil? %>
            <%= t("certification_cases.compliance_not_applicable") %>
          <% else %>
            <%= number_to_currency(row.amount, precision: 2) %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
  <tfoot>
    <tr>
      <td colspan="3"><%= t("#{i18n}.total_reported") %></td>
      <td><%= number_to_currency(compliance.income_table_total, precision: 2) %></td>
    </tr>
    <tr>
      <td colspan="3"><%= t("#{i18n}.required") %></td>
      <td><%= number_to_currency(compliance.income_table_target, precision: 2) %></td>
    </tr>
    <% if compliance.income_table_additional_needed.positive? %>
      <tr>
        <td colspan="3"><strong><%= t("#{i18n}.additional_income_needed") %></strong></td>
        <td><%= number_to_currency(compliance.income_table_additional_needed, precision: 2) %></td>
      </tr>
    <% end %>
  </tfoot>
</table>
