<%# OSCER-337 frame: Exemption under review (Figma pending-review mock) %>
<% compliance = local_assigns.fetch(:compliance) %>

<div class="member-dashboard-compliance__exemption-status">
  <div class="member-dashboard-compliance__alert member-dashboard-compliance__alert--review"
       role="alert"
       aria-labelledby="member-compliance-exemption-pending-review-alert-heading">
    <h3 id="member-compliance-exemption-pending-review-alert-heading" class="member-dashboard-compliance__alert-heading">
      <%= t("dashboard.member_compliance.exemption_alerts.pending_review.title") %>
    </h3>
    <p class="member-dashboard-compliance__alert-text">
      <%= t("dashboard.member_compliance.exemption_alerts.pending_review.body") %>
    </p>
  </div>

  <%= render "dashboard/member_compliance_exemption_history", compliance: compliance %>

  <p class="member-dashboard-compliance__status-footer">
    <%= t("dashboard.member_compliance.exemption_alerts.pending_review.footer") %>
  </p>
</div>
