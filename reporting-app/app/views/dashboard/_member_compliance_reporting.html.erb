<%# Reporting section on the not-exempt / denied-exemption dashboard (OSCER-642).
    Heading + (intro before reporting, data-driven activity tables once reporting) + CTAs.
    Progress cards land in #643. %>
<% compliance = local_assigns.fetch(:compliance) %>
<% activity_report = local_assigns[:activity_report] %>
<% certification_case = local_assigns[:certification_case] %>

<section class="member-dashboard-compliance__reporting margin-top-4" aria-labelledby="member-compliance-reporting-heading">
  <h2 id="member-compliance-reporting-heading" class="font-heading-lg margin-bottom-2"><%= t("dashboard.member_compliance.reporting.heading") %></h2>

  <% if activity_report.present? %>
    <% if compliance.hours_has_data? || compliance.income_has_data? %>
      <div class="member-dashboard-compliance__tables margin-bottom-3">
        <% if compliance.hours_has_data? %>
          <%= render "dashboard/member_compliance_hours_table", compliance: compliance %>
        <% end %>
        <% if compliance.income_has_data? %>
          <%= render "dashboard/member_compliance_income_table", compliance: compliance %>
        <% end %>
      </div>
    <% else %>
      <p class="member-dashboard-compliance__reporting-empty"><%= t("dashboard.member_compliance.reporting.no_activity_reported") %></p>
    <% end %>
  <% else %>
    <p class="member-dashboard-compliance__reporting-intro">
      <% if compliance.show_income_summary %>
        <%= t("dashboard.member_compliance.reporting.intro",
              target_hours: compliance.target_hours,
              target_income: number_to_currency(IncomeComplianceDeterminationService::TARGET_INCOME_MONTHLY, precision: 0),
              due_date: member_compliance_due_date(compliance),
              coverage_month: member_compliance_coverage_month(compliance)) %>
      <% else %>
        <%= t("dashboard.member_compliance.reporting.intro_hours",
              target_hours: compliance.target_hours,
              due_date: member_compliance_due_date(compliance),
              coverage_month: member_compliance_coverage_month(compliance)) %>
      <% end %>
    </p>
  <% end %>

  <% if member_compliance_activity_report_editable?(compliance, activity_report: activity_report) %>
    <% action = member_compliance_activity_report_action(compliance: compliance) %>
    <div class="member-dashboard-compliance__reporting-actions">
      <%= link_to action[:label], action[:path],
            class: "usa-button usa-button--outline margin-right-2 margin-bottom-1" %>
      <%= link_to t("dashboard.member_compliance.reporting.submit_button"),
            member_compliance_activity_report_submit_path(activity_report),
            class: "usa-button margin-bottom-1" %>
    </div>
  <% elsif activity_report.blank? %>
    <% action = member_compliance_activity_report_action(compliance: compliance) %>
    <%= link_to action[:label], action[:path], class: "usa-button" %>
  <% end %>
</section>
