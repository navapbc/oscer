<%# Activity report denied (OSCER-642): error alert + reported activity tables, with a
    supplementary link to the report and a resubmit CTA while the window is open. %>
<% show_resubmit = should_show_submit_new_activity_report_form?(certification_case) %>
<%= render "dashboard/member_compliance_dashboard",
           compliance: compliance,
           activity_report: activity_report,
           certification_case: certification_case,
           state_alert: {
             type: AlertComponent::TYPES::ERROR,
             heading: t(".heading"),
             message: t(".intro")
           },
           primary_action_label: t(".view_activity_report_button"),
           primary_action_path: activity_report_application_form_path(activity_report),
           secondary_action_label: (t(".submit_new_activity_report_button") if show_resubmit),
           secondary_action_path: (new_activity_report_application_form_path(certification_case_id: certification_case&.id) if show_resubmit) %>
