<%# Does not qualify — delegates to the compliance dashboard (OSCER-337 / #640).
    No retake-screener CTA after a caseworker denial (per AC). Reporting uses the
    existing activity-report flow until the dashboard reporting section (#642). %>
<% report_action = member_compliance_activity_report_action(compliance: compliance) %>

<%= render "dashboard/member_compliance_dashboard",
           compliance: compliance,
           primary_action_label: report_action[:label],
           primary_action_path: report_action[:path],
           secondary_action_label: t(".view_exemption_button"),
           secondary_action_path: exemption_application_form_path(compliance.exemption_application_form),
           show_reporting_intro: true %>
