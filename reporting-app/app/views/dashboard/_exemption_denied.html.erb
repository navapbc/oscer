<%# Does not qualify — delegates to the compliance dashboard (OSCER-337 / #640).
    No retake-screener CTA after a caseworker denial (per AC). Reporting uses the
    existing activity-report flow until the dashboard reporting section (#642). %>
<% report_action = member_compliance_activity_report_action(
     activity_report: local_assigns[:activity_report],
     certification_case: certification_case
   ) %>
<% dashboard_locals = {
     compliance: compliance,
     activity_report: local_assigns[:activity_report],
     exemption_application: exemption_application,
     certification_case: certification_case,
     current_period: current_period,
     target_hours: target_hours,
     period_end_date: period_end_date,
     total_hours_reported: total_hours_reported,
     hours_needed: hours_needed,
     primary_action_label: report_action[:label],
     primary_action_path: report_action[:path],
     secondary_action_label: t(".view_exemption_button"),
     secondary_action_path: exemption_application_form_path(exemption_application),
     show_reporting_intro: true
   } %>
<%= render "dashboard/member_compliance_dashboard", **dashboard_locals %>
