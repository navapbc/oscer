<% compliance = local_assigns.fetch(:compliance) %>
<% rows = compliance.member_hour_rows %>

<h3 class="font-heading-md margin-bottom-2"><%= member_compliance_activity_report_title(compliance) %></h3>

<table class="usa-table width-full member-dashboard-compliance__table certification-case-compliance-table">
  <thead>
    <tr>
      <th scope="col"><%= t("dashboard.member_compliance.hours_table.organization_name") %></th>
      <th scope="col"><%= t("dashboard.member_compliance.hours_table.source") %></th>
      <th scope="col"><%= t("dashboard.member_compliance.hours_table.activity_type") %></th>
      <th scope="col"><%= t("dashboard.member_compliance.hours_table.hours_reported") %></th>
    </tr>
  </thead>
  <tbody>
    <% rows.each do |row| %>
      <tr>
        <td><%= row.organization_name %></td>
        <td><%= member_compliance_source_label(row.source_token) %></td>
        <td><%= row.activity_type_label %></td>
        <td><%= number_with_precision(row.hours, precision: 0) %></td>
      </tr>
    <% end %>
  </tbody>
  <tfoot>
    <tr>
      <td colspan="3"><%= t("dashboard.member_compliance.hours_table.total_reported") %></td>
      <td><%= compliance.total_hours_reported %></td>
    </tr>
    <tr>
      <td colspan="3"><%= t("dashboard.member_compliance.hours_table.required") %></td>
      <td><%= compliance.target_hours %></td>
    </tr>
    <tr>
      <td colspan="3"><strong><%= t("dashboard.member_compliance.hours_table.additional_hours_needed") %></strong></td>
      <td><%= compliance.hours_needed %></td>
    </tr>
  </tfoot>
</table>
