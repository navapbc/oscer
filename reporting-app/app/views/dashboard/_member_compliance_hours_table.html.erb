<%# Data-driven hours table for the member dashboard (OSCER-642).
    Mirrors the staff certification_cases/_hours_reported_table columns and footer. %>
<% compliance = local_assigns.fetch(:compliance) %>
<% i18n = "dashboard.member_compliance.hours_table" %>

<table class="usa-table width-full certification-case-compliance-table member-dashboard-compliance__table member-dashboard-compliance__table--hours">
  <thead>
    <tr>
      <th scope="col"><%= t("#{i18n}.organization_name") %></th>
      <th scope="col"><%= t("#{i18n}.source") %></th>
      <th scope="col"><%= t("#{i18n}.activity_type") %></th>
      <th scope="col"><%= t("#{i18n}.hours_reported") %></th>
    </tr>
  </thead>
  <tbody>
    <% compliance.hour_table_rows.each do |row| %>
      <tr>
        <td><%= row.organization_name %></td>
        <td><%= member_compliance_source_label(row.source_token) %></td>
        <td><%= row.activity_type_label %></td>
        <td>
          <% if row.hours.nil? %>
            <%= t("certification_cases.compliance_not_applicable") %>
          <% else %>
            <%= number_with_precision(row.hours, precision: 0) %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
  <tfoot>
    <tr>
      <td colspan="3"><%= t("#{i18n}.total_reported") %></td>
      <td><%= number_with_precision(compliance.total_hours_reported, precision: 0) %></td>
    </tr>
    <tr>
      <td colspan="3"><%= t("#{i18n}.required") %></td>
      <td><%= compliance.target_hours %></td>
    </tr>
    <% if compliance.hours_needed.positive? %>
      <tr>
        <td colspan="3"><strong><%= t("#{i18n}.additional_hours_needed") %></strong></td>
        <td><%= number_with_precision(compliance.hours_needed, precision: 0) %></td>
      </tr>
    <% end %>
  </tfoot>
</table>
