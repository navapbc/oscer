<%# Exemption outcome states — alerts, history, badges (OSCER-337 / #640).
    Handles approved (exempt), pending review, and denied (does not qualify).
    Draft and get-started states are owned by other slices (#641, #639). %>
<% compliance = local_assigns.fetch(:compliance) %>

<% exemption_section_labelledby = if show_member_compliance_exemption_details_heading?(compliance)
                                    "exemption-details-heading"
                                  elsif member_compliance_exemption_pending_review_screen?(compliance)
                                    "member-compliance-exemption-pending-review-alert-heading"
                                  end %>
<section class="member-dashboard-compliance__exemption margin-bottom-4"
         <%= tag.attributes("aria-labelledby": exemption_section_labelledby) if exemption_section_labelledby.present? %>>
  <% if show_member_compliance_exemption_details_heading?(compliance) %>
    <h2 id="exemption-details-heading" class="font-heading-lg margin-bottom-2"><%= t("dashboard.member_compliance.exemption_details_heading") %></h2>
  <% end %>

  <% case compliance.exemption_flow_state %>
  <% when MemberDashboardCompliance::EXEMPTION_PENDING_REVIEW %>
    <%= render "dashboard/member_compliance_exemption_pending_review", compliance: compliance %>

  <% when MemberDashboardCompliance::EXEMPTION_APPROVED %>
    <%= render "dashboard/member_compliance_exemption_approved", compliance: compliance %>

  <% when MemberDashboardCompliance::EXEMPTION_DENIED %>
    <%= render "dashboard/member_compliance_exemption_denied", compliance: compliance %>
  <% end %>

  <% if local_assigns[:exemption_supplementary_button_label].present? && local_assigns[:exemption_supplementary_button_path].present? %>
    <div class="member-dashboard-compliance__exemption-action">
      <%= link_to local_assigns[:exemption_supplementary_button_label],
            local_assigns[:exemption_supplementary_button_path],
            class: "usa-button" %>
    </div>
  <% end %>
</section>
