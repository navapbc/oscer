<%# Shared member compliance shell (OSCER-337).
    Renders the exemption block (outcome/draft frames, #640/#641) and the reporting section
    with data-driven activity tables (#642). The exemption block is skipped for a not-exempt
    member who is simply reporting (EXEMPTION_NOT_STARTED). Progress cards land in #643.
    Requires +compliance+ — callers without a read model use other dashboard partials. %>
<% compliance = local_assigns.fetch(:compliance) %>
<% activity_report = local_assigns[:activity_report] %>
<% certification_case = local_assigns[:certification_case] %>

<div class="member-dashboard-compliance">
  <% if local_assigns[:state_alert].present? %>
    <% alert = local_assigns[:state_alert] %>
    <div class="margin-bottom-4">
      <%= render AlertComponent.new(
            type: alert[:type],
            heading: alert[:heading],
            message: alert[:message],
            heading_level: 3
          ) %>
    </div>
  <% end %>

  <% unless compliance.exemption_flow_state == MemberDashboardCompliance::EXEMPTION_NOT_STARTED %>
    <%= render "dashboard/member_compliance_exemption", compliance: compliance %>
  <% end %>

  <% if !local_assigns[:skip_reporting_section] &&
        show_member_compliance_reporting_section?(compliance, activity_report: activity_report) %>
    <%= render "dashboard/member_compliance_reporting",
               compliance: compliance,
               activity_report: activity_report,
               certification_case: certification_case %>
  <% end %>

  <% if local_assigns[:primary_action_label].present? && local_assigns[:primary_action_path].present? ||
        local_assigns[:secondary_action_label].present? && local_assigns[:secondary_action_path].present? %>
    <div class="member-dashboard-compliance__exemption-action margin-top-3">
      <% if local_assigns[:primary_action_label].present? && local_assigns[:primary_action_path].present? %>
        <%= link_to local_assigns[:primary_action_label],
              local_assigns[:primary_action_path],
              class: "usa-button margin-right-2 margin-bottom-1" %>
      <% end %>
      <% if local_assigns[:secondary_action_label].present? && local_assigns[:secondary_action_path].present? %>
        <%= link_to local_assigns[:secondary_action_label],
              local_assigns[:secondary_action_path],
              class: "usa-button usa-button--outline margin-right-2 margin-bottom-1" %>
      <% end %>
    </div>
  <% end %>
</div>
