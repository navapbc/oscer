<%# Shared member compliance shell (OSCER-337 / #480) %>
<% compliance = local_assigns.fetch(:compliance) %>
<% activity_report = local_assigns[:activity_report] %>
<% exemption_application = local_assigns[:exemption_application] %>
<% certification_case = local_assigns[:certification_case] %>
<% continue_path = local_assigns[:activity_report_continue_path] %>

<div class="grid-container member-dashboard-compliance">
  <% if compliance.present? %>
    <%= render "dashboard/member_compliance_exemption",
               compliance: compliance,
               certification_case: certification_case,
               exemption_application: exemption_application,
               activity_report: activity_report,
               suppress_exemption_denied_alert: local_assigns[:state_alert].present? &&
                 compliance.exemption_flow_state == MemberDashboardCompliance::EXEMPTION_DENIED %>

    <% if show_member_compliance_reporting_section?(compliance, activity_report: activity_report) %>
      <%= render "dashboard/member_compliance_reporting",
                 compliance: compliance,
                 activity_report: activity_report,
                 activity_report_continue_path: continue_path,
                 certification_case: certification_case %>
    <% end %>
  <% else %>
    <%= render "dashboard/compliance_status",
               current_period: local_assigns[:current_period],
               target_hours: local_assigns[:target_hours],
               period_end_date: local_assigns[:period_end_date],
               total_hours_reported: local_assigns[:total_hours_reported],
               hours_needed: local_assigns[:hours_needed] %>
  <% end %>

  <% if local_assigns[:state_alert].present? %>
    <% alert = local_assigns[:state_alert] %>
    <div class="margin-top-3">
      <%= render AlertComponent.new(
            type: alert[:type],
            heading: alert[:heading],
            message: alert[:message],
            heading_level: 3
          ) %>
    </div>
  <% end %>

  <% if local_assigns[:supplementary_button_label].present? && local_assigns[:supplementary_button_path].present? %>
    <div class="margin-top-3">
      <%= link_to local_assigns[:supplementary_button_label],
            local_assigns[:supplementary_button_path],
            class: "usa-button" %>
    </div>
  <% end %>
</div>
