<%= strata_form_with(model: [activity_report_application_form, activity.becomes(Activity)]) do |f| %>
  <%= f.text_field :name, label: t(".name") %>
  <%= f.select :month,
    6.times.map { |i|
      date = (Date.today - i.months).beginning_of_month
      [date.strftime("%B %Y"), date]
    }, { prompt: "- Select -" }
  %>
  <%= f.fieldset "Type" do %>
    <%= f.radio_button :type, :work_activity, label: "Hours", tile: false, checked: (activity.type == "WorkActivity") %>
    <%= f.radio_button :type, :earned_income_activity, label: "Earned Income", tile: false, checked: (activity.type == "EarnedIncomeActivity") %>
  <% end %>
  <%= f.text_field :input, inputmode: "decimal", id: "activities-hours-input", label: "How many hours? / How much earned income?", value: activity.try(:hours) || activity.try(:earned_income)&.dollar_amount %>
  <%= f.submit t(".continue"), big: true %>
<% end %>
