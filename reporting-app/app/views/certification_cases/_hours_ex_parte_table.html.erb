<% total_hours = hours_summary[:total_hours] %>
<% hours_needed = [target_hours - total_hours, 0].max %>
<% has_activities = external_hourly_activities.any? || member_activities.any? { |a| !a.read_attribute(:hours).nil? } %>
<% i18n = "certification_cases.hours_reported_table" %>
<% common = "certification_cases.common" %>

<% if has_activities %>
  <h3><%= t("#{i18n}.title") %></h3>
  <table class="usa-table usa-table--borderless width-full certification-case-hours-table-standard">
    <thead>
      <tr>
        <th scope="col"><%= t("#{i18n}.organization_name") %></th>
        <th scope="col"><%= t("#{i18n}.source") %></th>
        <th scope="col"><%= t("#{i18n}.activity_type") %></th>
        <th scope="col"><%= t("#{i18n}.hours_reported") %></th>
      </tr>
    </thead>
    <tbody>
      <% external_hourly_activities.each do |activity| %>
        <% category_name = activity.category.titleize %>
        <tr>
          <td><%= category_name %> <%= t("#{common}.activity_label") %></td>
          <td><%= t("#{common}.source_external", state_name: ENV.fetch("STATE_NAME", "the State")) %></td>
          <td><%= category_name %></td>
          <td><%= number_with_precision(activity.hours, precision: 0) %></td>
        </tr>
      <% end %>
      <% member_activities.each do |activity| %>
        <tr>
          <td><%= activity.name %></td>
          <td><%= t("#{common}.source_self_reported") %></td>
          <td><%= activity.category.titleize %></td>
          <td>
            <% if activity.read_attribute(:hours).nil? %>
              <%= t("certification_cases.compliance_not_applicable") %>
            <% else %>
              <%= number_with_precision(activity.hours, precision: 0) %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
    <tfoot>
      <tr>
        <td colspan="3"><%= t("#{i18n}.total_reported") %></td>
        <td><%= number_with_precision(total_hours, precision: 0) %></td>
      </tr>
      <tr>
        <td colspan="3"><%= t("#{i18n}.required") %></td>
        <td><%= target_hours %></td>
      </tr>
      <% if hours_needed > 0 %>
        <tr>
          <td colspan="3"><%= t("#{i18n}.additional_hours_needed") %></td>
          <td><%= number_with_precision(hours_needed, precision: 0) %></td>
        </tr>
      <% end %>
    </tfoot>
  </table>
<% end %>
