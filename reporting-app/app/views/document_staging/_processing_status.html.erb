<div class="usa-modal-wrapper is-visible" role="dialog" aria-labelledby="scanning-modal-heading" aria-describedby="scanning-modal-description">
  <div class="usa-modal-overlay is-visible" aria-controls="scanning-modal">
    <div class="usa-modal" id="scanning-modal" tabindex="-1" aria-labelledby="scanning-modal-heading" aria-describedby="scanning-modal-description">
      <div class="usa-modal__content">
        <div class="usa-modal__main">
          <h2 class="usa-modal__heading" id="scanning-modal-heading">
            <%= t("document_staging.processing.modal_title") %>
          </h2>
          <div class="usa-prose">
            <p id="scanning-modal-description"><%= t("document_staging.processing.modal_body") %></p>
            <p><%= t("document_staging.processing.time_warning") %></p>

            <p class="text-bold margin-bottom-05"><%= t("document_staging.processing.scanning") %></p>
            <div class="bg-base-lightest radius-pill overflow-hidden" style="height: 12px;">
              <div class="bg-primary radius-pill" style="height: 100%; width: 40%; animation: scanning-progress 90s linear infinite;"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
